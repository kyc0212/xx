<!DOCTYPE html>
<html lang="zh-TW">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>星空食研所 - QR Code 點餐系統</title>
    <!-- 引入 Tailwind CSS -->
    <script src="https://cdn.tailwindcss.com"></script>
    <!-- 引入 Lucide 圖示 -->
    <script src="https://unpkg.com/lucide@latest"></script>
    <!-- 引入 Google 字體 -->
    <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+TC:wght@400;500;700;900&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Noto Sans TC', sans-serif; }
        .animate-slide-up { animation: slide-up 0.5s cubic-bezier(0.16, 1, 0.3, 1); }
        @keyframes slide-up { from { transform: translateY(100%); opacity: 0; } to { transform: translateY(0); opacity: 1; } }
        .hide-scrollbar::-webkit-scrollbar { display: none; }
    </style>
</head>
<body class="bg-gray-50">

    <div id="app">
        <!-- 內容由 JavaScript 動態生成 -->
    </div>

    <script>
        // --- 數據設定 ---
        const MENU_DATA = [
            { id: 1, name: '招牌經典牛肉堡', price: 180, category: '主食', image: 'https://images.unsplash.com/photo-1568901346375-23c9450c58cd?w=500&q=80', description: '手工手打牛肉排，搭配鮮脆生菜與秘製醬汁。' },
            { id: 2, name: '松露菌菇義大利麵', price: 220, category: '主食', image: 'https://images.unsplash.com/photo-1473093226795-af9932fe5856?w=500&q=80', description: '濃郁松露香氣，搭配多種現炒菌菇。' },
            { id: 3, name: '酥炸黃金脆薯', price: 80, category: '小吃', image: 'https://images.unsplash.com/photo-1573080496219-bb080dd4f877?w=500&q=80', description: '外酥內軟，特選進口馬鈴薯。' },
            { id: 4, name: '冰萃冷泡茶', price: 60, category: '飲品', image: 'https://images.unsplash.com/photo-1544787210-2211d7c309c7?w=500&q=80', description: '低溫萃取，回甘不澀。' },
            { id: 5, name: '提拉米蘇', price: 120, category: '甜點', image: 'https://images.unsplash.com/photo-1571877227200-a0d98ea607e9?w=500&q=80', description: '正宗義式經典，香醇馬斯卡彭乳酪。' }
        ];

        let state = {
            view: 'customer', // 'customer' or 'admin'
            cart: {},
            orders: [],
            tableNumber: 'B-03',
            siteUrl: window.location.href.split('?')[0]
        };

        // --- 初始化桌號偵測 ---
        const params = new URLSearchParams(window.location.search);
        if (params.get('table')) state.tableNumber = params.get('table');

        // --- 核心渲染函數 ---
        function render() {
            const app = document.getElementById('app');
            if (state.view === 'customer') {
                app.innerHTML = renderCustomerView();
            } else {
                app.innerHTML = renderAdminView();
            }
            lucide.createIcons(); // 重新渲染圖示
        }

        // --- 前台畫面 ---
        function renderCustomerView() {
            const cartDetails = getCartDetails();
            return `
                <div class="flex flex-col min-h-screen bg-white pb-24">
                    <header class="bg-white/80 backdrop-blur-md p-5 shadow-sm sticky top-0 z-20 flex justify-between items-center border-b">
                        <div class="flex items-center space-x-2">
                            <div class="w-8 h-8 bg-orange-500 rounded-lg flex items-center justify-center text-white"><i data-lucide="store" size="18"></i></div>
                            <div>
                                <h1 class="text-lg font-black tracking-tight">星空食研所</h1>
                                <p class="text-[10px] text-orange-500 font-bold flex items-center">
                                    <span class="w-1.5 h-1.5 bg-orange-500 rounded-full mr-1 animate-pulse"></span>
                                    內用桌號：${state.tableNumber}
                                </p>
                            </div>
                        </div>
                        <button onclick="switchView('admin')" class="text-xs font-bold text-slate-400 border border-slate-200 px-3 py-1.5 rounded-full hover:bg-slate-50">管理後台</button>
                    </header>

                    <main class="max-w-2xl mx-auto w-full p-4 space-y-8 mt-2">
                        <div class="relative h-40 rounded-3xl overflow-hidden shadow-lg">
                            <img src="https://images.unsplash.com/photo-1504674900247-0877df9cc836?w=800&q=80" class="w-full h-full object-cover">
                            <div class="absolute inset-0 bg-gradient-to-t from-black/60 flex items-end p-6"><h2 class="text-white text-xl font-bold">歡迎光臨，請開始點餐</h2></div>
                        </div>

                        ${['主食', '小吃', '飲品', '甜點'].map(cat => `
                            <section>
                                <h2 class="text-xl font-black text-slate-800 mb-5">${cat}</h2>
                                <div class="grid grid-cols-1 gap-4">
                                    ${MENU_DATA.filter(i => i.category === cat).map(item => `
                                        <div class="bg-white rounded-3xl p-3 flex border border-slate-100 shadow-sm">
                                            <img src="${item.image}" class="w-24 h-24 object-cover rounded-2xl">
                                            <div class="ml-4 flex-1 flex flex-col justify-between">
                                                <div>
                                                    <h3 class="font-bold text-slate-800">${item.name}</h3>
                                                    <p class="text-[11px] text-slate-400 line-clamp-1">${item.description}</p>
                                                </div>
                                                <div class="flex justify-between items-end">
                                                    <span class="text-lg font-black text-orange-500">$${item.price}</span>
                                                    <div class="flex items-center space-x-3 bg-slate-50 rounded-xl p-1 px-2">
                                                        <button onclick="updateCart(${item.id}, -1)" class="w-6 h-6 bg-white rounded-lg shadow-sm flex items-center justify-center"><i data-lucide="minus" size="12"></i></button>
                                                        <span class="text-xs font-bold">${state.cart[item.id] || 0}</span>
                                                        <button onclick="updateCart(${item.id}, 1)" class="w-6 h-6 bg-white rounded-lg shadow-sm flex items-center justify-center"><i data-lucide="plus" size="12"></i></button>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    `).join('')}
                                </div>
                            </section>
                        `).join('')}
                    </main>

                    ${cartDetails.count > 0 ? `
                        <div class="fixed bottom-8 left-1/2 -translate-x-1/2 w-[calc(100%-2rem)] max-w-lg bg-slate-900 text-white p-5 rounded-[2rem] shadow-2xl flex justify-between items-center animate-slide-up z-30 ring-4 ring-white">
                            <div class="flex items-center">
                                <div class="relative mr-4 bg-orange-500 p-2.5 rounded-2xl">
                                    <i data-lucide="shopping-bag" size="22"></i>
                                    <span class="absolute -top-2 -right-2 bg-white text-slate-900 text-[10px] w-6 h-6 flex items-center justify-center rounded-full font-black">${cartDetails.count}</span>
                                </div>
                                <p class="text-xl font-black">$${cartDetails.total}</p>
                            </div>
                            <button onclick="submitOrder()" class="bg-white text-slate-900 px-8 py-3 rounded-2xl font-black">送出訂單</button>
                        </div>
                    ` : ''}
                </div>
            `;
        }

        // --- 後台畫面 ---
        function renderAdminView() {
            const qrUrl = `${state.siteUrl}${state.siteUrl.includes('?') ? '&' : '?'}table=${state.tableNumber}`;
            const qrImage = `https://api.qrserver.com/v1/create-qr-code/?size=300x300&data=${encodeURIComponent(qrUrl)}&margin=10`;

            return `
                <div class="flex flex-col md:flex-row min-h-screen bg-slate-50">
                    <aside class="w-full md:w-64 bg-slate-900 text-white p-6 flex flex-col">
                        <div class="flex items-center space-x-3 mb-10"><div class="bg-orange-500 p-2 rounded-lg"><i data-lucide="utensils"></i></div><h1 class="font-black text-xl">管理系統</h1></div>
                        <nav class="flex-1 space-y-4">
                            <div class="flex items-center space-x-3 text-orange-500 bg-white/5 p-4 rounded-xl font-bold"><i data-lucide="layout-dashboard" size="20"></i><span>訂單管理</span></div>
                        </nav>
                        <button onclick="switchView('customer')" class="mt-10 flex items-center justify-center space-x-2 bg-slate-800 p-4 rounded-xl font-bold text-slate-400 hover:text-white transition-colors">
                            <i data-lucide="arrow-left" size="18"></i><span>回首頁</span>
                        </button>
                    </aside>

                    <main class="flex-1 p-6 md:p-10 space-y-10">
                        <div class="grid grid-cols-1 lg:grid-cols-2 gap-10">
                            <div>
                                <h2 class="text-2xl font-black mb-6 flex items-center"><i data-lucide="clipboard-list" class="mr-2 text-orange-500"></i>即時訂單</h2>
                                ${state.orders.length === 0 ? '<div class="bg-white p-10 rounded-3xl text-center text-slate-300 font-bold border-2 border-dashed">目前無訂單</div>' : 
                                    state.orders.map(o => `
                                        <div class="bg-white p-6 rounded-3xl shadow-sm border mb-4">
                                            <div class="flex justify-between font-black mb-4"><span>桌號：${o.table}</span><span class="text-slate-400">#${o.id}</span></div>
                                            <div class="text-sm space-y-1 mb-4">${o.items.map(it => `<div class="flex justify-between"><span>${it.name} x ${it.quantity}</span><span>$${it.price * it.quantity}</span></div>`).join('')}</div>
                                            <div class="pt-4 border-t flex justify-between items-center"><span class="font-black text-xl">$${o.total}</span><span class="text-[10px] bg-blue-50 text-blue-600 px-2 py-1 rounded-full">製作中</span></div>
                                        </div>
                                    `).join('')
                                }
                            </div>

                            <div class="bg-white p-8 rounded-3xl shadow-sm border h-fit">
                                <h2 class="text-xl font-black mb-6 flex items-center"><i data-lucide="qr-code" class="mr-2 text-orange-500"></i>QR Code 設定</h2>
                                <div class="space-y-6">
                                    <div>
                                        <label class="text-[10px] font-black text-slate-400 uppercase tracking-widest block mb-2">部署網址</label>
                                        <input type="text" id="urlInput" value="${state.siteUrl}" onchange="updateUrl(this.value)" class="w-full bg-slate-50 border p-3 rounded-xl text-xs font-mono outline-none focus:ring-2 focus:ring-orange-500">
                                    </div>
                                    <div class="flex flex-col items-center p-4 bg-slate-50 rounded-2xl">
                                        <img src="${qrImage}" class="w-48 h-48 bg-white p-2 rounded-xl shadow-inner">
                                        <p class="mt-4 text-sm font-black text-slate-800">桌號：${state.tableNumber}</p>
                                        <p class="text-[10px] text-slate-400 mt-1 max-w-[200px] truncate">${qrUrl}</p>
                                    </div>
                                    <button onclick="window.open('${qrImage}')" class="w-full bg-slate-900 text-white py-4 rounded-2xl font-black text-xs flex items-center justify-center hover:bg-orange-500 transition-colors">
                                        <i data-lucide="external-link" size="14" class="mr-2"></i>下載 QR Code 圖片
                                    </button>
                                </div>
                            </div>
                        </div>
                    </main>
                </div>
            `;
        }

        // --- 邏輯函數 ---
        function updateCart(id, delta) {
            const current = state.cart[id] || 0;
            const next = current + delta;
            if (next <= 0) delete state.cart[id];
            else state.cart[id] = next;
            render();
        }

        function getCartDetails() {
            let total = 0, count = 0, items = [];
            Object.keys(state.cart).forEach(id => {
                const item = MENU_DATA.find(m => m.id === parseInt(id));
                if (item) {
                    total += item.price * state.cart[id];
                    count += state.cart[id];
                    items.push({ ...item, quantity: state.cart[id] });
                }
            });
            return { total, count, items };
        }

        function submitOrder() {
            const details = getCartDetails();
            const newOrder = {
                id: Math.floor(Math.random() * 9000) + 1000,
                table: state.tableNumber,
                items: details.items,
                total: details.total
            };
            state.orders.push(newOrder);
            state.cart = {};
            // 這裡可以加入簡單的動畫或通知
            alert('訂單已送出！桌號：' + state.tableNumber);
            render();
        }

        function switchView(view) {
            state.view = view;
            render();
        }

        function updateUrl(url) {
            state.siteUrl = url;
            render();
        }

        // 初始渲染
        window.onload = render;
    </script>
</body>
</html>
